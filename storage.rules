rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /pegawai/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == "choiruddin2410@gmail.com";
      allow delete: if request.auth != null && request.auth.token.email == "choiruddin2410@gmail.com";
    }
  }
}
